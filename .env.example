# Root environment file for Docker Compose

# Supabase PostgreSQL Connection String (Transaction mode / Session mode)
# Example: postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=your_remote_supabase_db_url_here

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
